# Environment configuration variables (Contains your real email/secrets)
.env
.env.*

# Local runtime data folder (Hides the DB, active JSONs, and backups automatically)
data/

# Loose database or backup files (in case they are outside the data folder)
*.db
auth_tracker_backup.json

# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Python testing / linting caches
.pytest_cache/
.ruff_cache/